# Copy this to .env for local testing (never commit .env to git)

# Get from @BotFather on Telegram
BOT_TOKEN=

# Your Telegram user ID — get it from @userinfobot
OWNER_CHAT_ID=
# Path to SQLite DB (Railway volumes or local)
DB_PATH=data/sites.db

# Port for health check (Railway sets this automatically)
PORT=8080

# Encryption key for backup files (change this to something secret!)
BACKUP_PASSWORD=change-me-to-something-secret
